   "source": [
    "# Compute power spectrum with k-range restriction: 1.0 <= k <= 3.0\n",
    "# This focuses on intermediate scales where the power-law is well-defined\n",
    "a = fbm3d_ISM(nx=nx,ny=ny,nz=nz,mach=mach, seed=seed, k_min=1.0, k_max=3.0, verbose=True)\n",
    "\n",
    "# Calculate power spectrum\n",
    "kr_a, PSD_a = calculate_PSD(a.data)\n",
    "\n",
    "# Calculate normalization factor for theoretical power-law\n",
    "ynorm = calculate_PSD_norm(a.data.shape, a.slope)\n",
    "\n",
    "# Theoretical power law: P(k) ∝ k^(-slope)\n",
    "y = kr_a**(-a.slope)*ynorm\n",
    "y[0] = 0.0  # Avoid singular point at k=0\n",
    "\n",
    "# Create plot\n",
    "fig, ax = plt.subplots(1,1, figsize=(5,5))\n",
    "lab = r'$P(\\vec{k}) \\propto k^{-%.2f}$' % (a.slope)\n",
    "\n",
    "ax.plot(kr_a[1:], y[1:], color='red', label=lab)        # Theoretical fit (red line)\n",
    "ax.scatter(kr_a[1:], PSD_a[1:],s=4.0, color='blue')     # Actual data (blue dots)\n",
    "ax.set_xscale('log')\n",
    "ax.set_yscale('log')\n",
    "ax.set_xlabel(r'$|\\vec{k}|$')\n",
    "ax.set_ylabel(r'$P(\\vec{k})$ of $\\rho$')\n",
    "ax.set_ylim(np.amin(y[1:])*0.5, np.amax(y[1:])*2)\n",
    "ax.legend(frameon=False)"
   ]
  },
